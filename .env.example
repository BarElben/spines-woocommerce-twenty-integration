# Copy this file to .env and fill in real values.
#   cp .env.example .env
# Never commit the real .env — it's excluded via .gitignore.
#
# Placeholders below are examples only. Generate real secrets with:
#   openssl rand -hex 32        (for *_SECRET / *_KEY style values)
#   openssl rand -base64 24     (works fine too)

# --- Public domains (reverse-proxied by Caddy, auto-HTTPS via Let's Encrypt) ---
# Using sslip.io wildcard DNS against the box's Elastic IP means no paid domain
# is required: <name>.<ip-with-dashes>.sslip.io resolves straight back to the IP.
DOMAIN_N8N=n8n.YOUR-ELASTIC-IP-WITH-DASHES.sslip.io
DOMAIN_TWENTY=crm.YOUR-ELASTIC-IP-WITH-DASHES.sslip.io
DOMAIN_WP=shop.YOUR-ELASTIC-IP-WITH-DASHES.sslip.io

# --- n8n ---
# Postgres password for the n8n-db service (n8n's own workflow/execution store).
N8N_DB_PASSWORD=changeme-generate-a-random-secret
# n8n uses this to encrypt stored credentials at rest. Generate once and never
# change it after n8n has saved credentials, or they become unreadable.
N8N_ENCRYPTION_KEY=changeme-generate-a-random-secret
# Must match the secret configured on the WooCommerce webhook (Woo -> Settings ->
# Advanced -> Webhooks). Verified in n8n via HMAC-SHA256 over the raw request body.
WC_WEBHOOK_SECRET=changeme-generate-a-random-secret

# --- Twenty CRM ---
# Postgres password for the twenty-db service.
TWENTY_DB_PASSWORD=changeme-generate-a-random-secret
# Twenty's own application secret (session/token signing).
TWENTY_APP_SECRET=changeme-generate-a-random-secret
# API key generated inside Twenty (Settings -> APIs & Webhooks -> create key).
# Used by the n8n workflow to authenticate GraphQL/REST calls to Twenty.
TWENTY_API_KEY=changeme-paste-the-key-generated-in-twenty-ui

# --- WordPress / WooCommerce (test shop) ---
WP_DB_PASSWORD=changeme-generate-a-random-secret
